VITE_API_URL=http://localhost:8000/api/v1

# Public submission API key — must match backend PUBLIC_SUBMISSION_API_KEY.
# Note: any VITE_* variable is bundled into the client JS and is not a
# real secret. It only acts as a deterrent alongside server-side rate
# limiting; for production add CAPTCHA / IP throttling as well.
VITE_PUBLIC_API_KEY=
